{
  "name": "environmental-metrics-server",
  "version": "2.0.0",
  "description": "Real-time environmental metrics server with persistence and alerting",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "client": "node client-example.js",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "test": "jest --testEnvironment=node",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": [
    "environmental",
    "metrics",
    "real-time",
    "websocket",
    "feathers",
    "sustainability"
  ],
  "author": "ACTORS Team",
  "license": "MIT",
  "dependencies": {
    "@feathersjs/feathers": "^5.0.0",
    "@feathersjs/express": "^5.0.0",
    "@feathersjs/socketio": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "eslint": "^8.55.0",
    "socket.io-client": "^4.7.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}